      "templateText": "{{SELECT (CASE WHEN SUM(CASE WHEN MV_EQ([捕獲等又は採取等の方法（使用する捕獲用具の名称)],'手捕り') THEN 1 ELSE 0 END) > 0 THEN '手捕り' ELSE '' END) AS [m1], (CASE WHEN SUM(CASE WHEN MV_EQ([捕獲等又は採取等の方法（使用する捕獲用具の名称)|わな|道具の種類],'はこわな') THEN 1 ELSE 0 END) > 0 THEN 'はこわな' ELSE '' END) AS [m2], (CASE WHEN SUM(CASE WHEN MV_EQ([捕獲等又は採取等の方法（使用する捕獲用具の名称)|わな|道具の種類],'くくりわな') THEN 1 ELSE 0 END) > 0 THEN 'くくりわな' ELSE '' END) AS [m3], (CASE WHEN SUM(CASE WHEN MV_EQ([捕獲等又は採取等の方法（使用する捕獲用具の名称)],'網') THEN 1 ELSE 0 END) > 0 THEN '網' ELSE '' END) AS [m4], (CASE WHEN SUM(CASE WHEN MV_EQ([捕獲等又は採取等の方法（使用する捕獲用具の名称)|銃器|銃の種類],'空気銃') THEN 1 ELSE 0 END) > 0 THEN '空気銃' ELSE '' END) AS [m5], (CASE WHEN SUM(CASE WHEN MV_EQ([捕獲等又は採取等の方法（使用する捕獲用具の名称)|銃器|銃の種類],'散弾銃') THEN 1 ELSE 0 END) > 0 THEN '散弾銃' ELSE '' END) AS [m6], (CASE WHEN SUM(CASE WHEN MV_EQ([捕獲等又は採取等の方法（使用する捕獲用具の名称)|銃器|銃の種類],'ライフル銃') THEN 1 ELSE 0 END) > 0 THEN 'ライフル銃' ELSE '' END) AS [m7] FROM [1Eh5p3Q5IMQEfi-7TiUV8ZZ8z_4HKW0Zj] WHERE [pid] = _id}}",
